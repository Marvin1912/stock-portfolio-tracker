# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_ENV=development                   # development | staging | production
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_HOSTS=["http://localhost:8000"]

# -----------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio
# Used by Alembic (sync driver) for migrations
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/portfolio

# -----------------------------------------------------------------------
# Email / SMTP  (issue #20)
# -----------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME="Stock Portfolio Tracker"
SMTP_USE_TLS=true

# -----------------------------------------------------------------------
# Scheduler  (issue #21)
# -----------------------------------------------------------------------
# Timezone used for APScheduler jobs (e.g. monthly report generation)
SCHEDULER_TIMEZONE=UTC
# Cron expression for monthly report job  (default: 1st of each month, 08:00)
MONTHLY_REPORT_CRON="0 8 1 * *"

# -----------------------------------------------------------------------
# Stock data provider  (future: price fetching)
# -----------------------------------------------------------------------
STOCK_API_KEY=your-api-key-here
STOCK_API_BASE_URL=https://api.example-stock-provider.com/v1

# -----------------------------------------------------------------------
# PDF import  (issue #16, #17)
# -----------------------------------------------------------------------
# Directory where uploaded broker PDFs are stored temporarily
PDF_UPLOAD_DIR=/tmp/portfolio_uploads
# Max upload size in bytes (default: 20 MB)
PDF_MAX_UPLOAD_BYTES=20971520

# -----------------------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------------------
JWT_ALGORITHM=HS256
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
